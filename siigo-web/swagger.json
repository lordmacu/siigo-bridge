    "/odata/{table}": {
      "get": {
        "tags": ["OData"],
        "summary": "Consultar coleccion OData",
        "description": "Query OData v4 con $top, $skip, $filter, $orderby, $select, $count.\n\nTablas: clients, products, movements, cartera, plan_cuentas, activos_fijos, saldos_terceros, saldos_consolidados, documentos, terceros_ampliados, transacciones_detalle, periodos_contables, condiciones_pago, libros_auxiliares, codigos_dane, actividades_ica, conceptos_pila, activos_fijos_detalle, audit_trail_terceros, clasificacion_cuentas.\n\n**$filter operators**: eq, ne, gt, ge, lt, le, contains(), startswith()\n\nEjemplo: `/odata/saldos_terceros?$top=50&$filter=contains(nit_tercero,'900')&$orderby=saldo_final desc&$count=true`",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "table", "in": "path", "required": true, "schema": {"type": "string", "enum": ["clients", "products", "movements", "cartera", "plan_cuentas", "activos_fijos", "saldos_terceros", "saldos_consolidados", "documentos", "terceros_ampliados", "transacciones_detalle", "periodos_contables", "condiciones_pago", "libros_auxiliares", "codigos_dane", "actividades_ica", "conceptos_pila", "activos_fijos_detalle", "audit_trail_terceros", "clasificacion_cuentas"]}, "description": "Tabla a consultar"},
          {"name": "$top", "in": "query", "schema": {"type": "integer", "default": 100, "maximum": 5000}, "description": "Maximo de registros a retornar"},
          {"name": "$skip", "in": "query", "schema": {"type": "integer", "default": 0}, "description": "Registros a saltar (paginacion)"},
          {"name": "$filter", "in": "query", "schema": {"type": "string"}, "description": "Filtro OData. Ejemplo: sync_status eq 'synced' and contains(nombre,'empresa')"},
          {"name": "$orderby", "in": "query", "schema": {"type": "string"}, "description": "Ordenamiento. Ejemplo: nombre desc, updated_at asc"},
          {"name": "$select", "in": "query", "schema": {"type": "string"}, "description": "Columnas (separadas por coma). Ejemplo: nit,nombre,sync_status"},
          {"name": "$count", "in": "query", "schema": {"type": "string", "enum": ["true", "false"]}, "description": "Incluir @odata.count"}
        ],
        "responses": {
          "200": {"description": "Resultado OData con @odata.context, value[], @odata.count, @odata.nextLink"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenido de POST /api/v1/auth. No requerido si JWT esta desactivado en configuracion."
      }
    },
    "parameters": {
      "page": {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1, "minimum": 1}, "description": "Numero de pagina"},
      "limit": {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 50, "minimum": 1, "maximum": 500}, "description": "Registros por pagina"},
      "search": {"name": "search", "in": "query", "schema": {"type": "string"}, "description": "Texto de busqueda (filtra por key y campos principales)"},
      "sync_status": {"name": "sync_status", "in": "query", "schema": {"type": "string", "enum": ["pending", "synced", "error"]}, "description": "Filtrar por estado de sincronizacion"},
      "since": {"name": "since", "in": "query", "schema": {"type": "string", "format": "date-time"}, "description": "Solo registros actualizados despues de esta fecha (ISO 8601)"}
    },
    "schemas": {
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Record"}, "description": "Lista de registros"},
          "total": {"type": "integer", "description": "Total de registros que coinciden", "example": 150},
          "page": {"type": "integer", "description": "Pagina actual", "example": 1},
          "limit": {"type": "integer", "description": "Registros por pagina", "example": 50}
        }
      },
      "Record": {
        "type": "object",
        "description": "Registro dinamico. Los campos varian segun la tabla. Todas las tablas incluyen: id, hash, sync_status, sync_action, sync_error, updated_at, synced_at. Campos numericos (saldo, debito, credito, valor) son decimales.",
        "additionalProperties": true,
        "example": {
          "id": 1,
          "nit": "900123456",
          "nombre": "EMPRESA EJEMPLO SAS",
          "sync_status": "synced",
          "updated_at": "2026-03-08T19:00:00Z"
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {"type": "string", "example": "Token invalido o expirado"}
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "No autorizado - Token JWT invalido, expirado o no proporcionado",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Error"}}}
      },
      "APIDisabled": {
        "description": "API publica deshabilitada",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Error"}, "example": {"error": "API deshabilitada"}}}
      },
      "NotFound": {
        "description": "Registro no encontrado",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Error"}, "example": {"error": "No encontrado"}}}
      }
    }
  }
}
