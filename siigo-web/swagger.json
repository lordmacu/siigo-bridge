    {"name": "SaldosTerceros", "description": "Saldos por tercero con BCD (Z25)"},
    {"name": "SaldosConsolidados", "description": "Saldos consolidados por cuenta con BCD (Z28)"},
    {"name": "Documentos", "description": "Documentos / Facturas detalle (Z11)"},
    {"name": "TercerosAmpliados", "description": "Terceros ampliados con email y direccion (Z08A)"},
    {"name": "TransaccionesDetalle", "description": "Transacciones detalle por linea (Z07T)"},
    {"name": "PeriodosContables", "description": "Periodos contables con saldos BCD (Z26)"},
    {"name": "CondicionesPago", "description": "Condiciones de pago (Z05)"},
    {"name": "LibrosAuxiliares", "description": "Libros auxiliares con saldos BCD (Z07)"},
    {"name": "CodigosDane", "description": "Codigos DANE de municipios colombianos"},
