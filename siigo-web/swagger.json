    "/api/detect-enabled": {
      "get": {
        "tags": [
          "SyncControl"
        ],
        "summary": "Obtener estado de deteccion por tabla",
        "description": "Retorna un mapa de 13 tablas con true/false indicando si la deteccion ISAM esta activa.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Mapa de deteccion",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "boolean"
                  },
                  "example": {
                    "clients": true,
                    "products": true
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "SyncControl"
        ],
        "summary": "Configurar deteccion por tabla",
        "description": "Activa o desactiva la deteccion ISAM → SQLite para cada tabla.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "boolean"
                },
                "example": {
                  "clients": true,
                  "products": false
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guardado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/send-enabled": {
      "get": {
        "tags": [
          "SyncControl"
        ],
        "summary": "Obtener estado de envio por tabla",
        "description": "Retorna un mapa de 13 tablas con true/false indicando si el envio a Laravel esta activo.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Mapa de envio",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "boolean"
                  },
                  "example": {
                    "clients": false,
                    "products": false
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "SyncControl"
        ],
        "summary": "Configurar envio por tabla",
        "description": "Activa o desactiva el envio SQLite → Laravel para cada tabla.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "boolean"
                },
                "example": {
                  "clients": true,
                  "products": true
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guardado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/postman": {
      "get": {
        "tags": [
          "Postman"
        ],
        "summary": "Exportar coleccion Postman v2.1",
        "description": "Genera dinamicamente una coleccion Postman con todos los endpoints, organizados por carpetas. Incluye Auth, 13 tablas de datos, OData, Sync Control, Config y User Management.",
        "responses": {
          "200": {
            "description": "Coleccion Postman JSON",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/odata": {
      "get": {
        "tags": [
          "OData"
        ],
        "summary": "OData service document",
        "description": "Retorna las 13 colecciones OData disponibles.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Service document con colecciones disponibles"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/odata/$metadata": {
      "get": {
        "tags": [
          "OData"
        ],
        "summary": "OData metadata (CSDL XML)",
        "description": "Schema CSDL XML con 13 EntityTypes, propiedades tipadas (Edm.Decimal para saldos, Edm.DateTimeOffset para fechas), NavigationProperty con ReferentialConstraint para relaciones. Power BI usa esto para auto-detectar relaciones entre tablas.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "CSDL XML con esquema de entidades y relaciones"
          }
        }
      }
    },
    "/odata/{table}": {
      "get": {
        "tags": [
          "OData"
        ],
        "summary": "Consultar coleccion OData",
        "description": "Query OData v4 con $top, $skip, $filter, $orderby, $select, $count.\n\nTablas: clients, products, cartera, documentos, condiciones_pago, codigos_dane, formulas, vendedores_areas.\n\n**$filter operators**: eq, ne, gt, ge, lt, le, contains(), startswith()\n\nEjemplo: `/odata/clients?$top=50&$filter=contains(nombre,'AROMA')&$orderby=nombre&$count=true`",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "clients",
                "products",
                "cartera",
                "documentos",
                "condiciones_pago",
                "codigos_dane",
                "formulas",
                "vendedores_areas"
              ]
            },
            "description": "Tabla a consultar"
          },
          {
            "name": "$top",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 5000
            },
            "description": "Maximo de registros a retornar"
          },
          {
            "name": "$skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Registros a saltar (paginacion)"
          },
          {
            "name": "$filter",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filtro OData. Ejemplo: sync_status eq 'synced' and contains(nombre,'empresa')"
          },
          {
            "name": "$orderby",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Ordenamiento. Ejemplo: nombre desc, updated_at asc"
          },
          {
            "name": "$select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Columnas (separadas por coma). Ejemplo: nit,nombre,sync_status"
          },
          {
            "name": "$count",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            },
            "description": "Incluir @odata.count"
          }
        ],
        "responses": {
          "200": {
            "description": "Resultado OData con @odata.context, value[], @odata.count, @odata.nextLink"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenido de POST /api/v1/auth. No requerido si JWT esta desactivado en configuracion."
      }
    },
    "parameters": {
      "page": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1,
          "minimum": 1
        },
        "description": "Numero de pagina"
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 50,
          "minimum": 1,
          "maximum": 500
        },
        "description": "Registros por pagina"
      },
      "search": {
        "name": "search",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Texto de busqueda (filtra por key y campos principales)"
      },
      "sync_status": {
        "name": "sync_status",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "pending",
            "synced",
            "error"
          ]
        },
        "description": "Filtrar por estado de sincronizacion"
      },
      "since": {
        "name": "since",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time"
        },
        "description": "Solo registros actualizados despues de esta fecha (ISO 8601)"
      }
    },
    "schemas": {
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Record"
            },
            "description": "Lista de registros"
          },
          "total": {
            "type": "integer",
            "description": "Total de registros que coinciden",
            "example": 150
          },
          "page": {
            "type": "integer",
            "description": "Pagina actual",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "description": "Registros por pagina",
            "example": 50
          }
        }
      },
      "Record": {
        "type": "object",
        "description": "Registro dinamico. Los campos varian segun la tabla. Todas las tablas incluyen: id, hash, sync_status, sync_action, sync_error, updated_at, synced_at. Campos numericos (saldo, debito, credito, valor) son decimales.",
        "additionalProperties": true,
        "example": {
          "id": 1,
          "nit": "900123456",
          "nombre": "EMPRESA EJEMPLO SAS",
          "sync_status": "synced",
          "updated_at": "2026-03-08T19:00:00Z"
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Token invalido o expirado"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "No autorizado - Token JWT invalido, expirado o no proporcionado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "APIDisabled": {
        "description": "API publica deshabilitada",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "error": "API deshabilitada"
            }
          }
        }
      },
      "NotFound": {
        "description": "Registro no encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "error": "No encontrado"
            }
          }
        }
      }
    }
  }
}