  "paths": {
    "/api/v1/auth": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Obtener token JWT",
        "description": "Dos metodos de autenticacion:\n\n**Metodo 1 - API Key:** Enviar `api_key`.\n\n**Metodo 2 - Credenciales:** Enviar `username` + `password` (usuarios del dashboard o root).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "api_key": {
                    "type": "string",
                    "example": "tu-clave-secreta",
                    "description": "Metodo 1: API key configurada"
                  },
                  "username": {
                    "type": "string",
                    "example": "admin",
                    "description": "Metodo 2: nombre de usuario"
                  },
                  "password": {
                    "type": "string",
                    "example": "mi-contrasena",
                    "description": "Metodo 2: contrasena del usuario"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token generado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIs..."
                    },
                    "expires_in": {
                      "type": "integer",
                      "example": 86400,
                      "description": "Segundos hasta expiracion"
                    },
                    "method": {
                      "type": "string",
                      "enum": [
                        "api_key",
                        "credentials"
                      ],
                      "description": "Metodo usado"
                    },
                    "user": {
                      "type": "string",
                      "description": "Usuario autenticado"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/APIDisabled"
          }
        }
      }
    },
